<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.taskflow.controller.DashboardController"
            stylesheets="@../css/style.css"
            styleClass="root-pane"
            prefWidth="1150" prefHeight="720">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="230" spacing="4">
            <VBox styleClass="sidebar-header" spacing="6">
                <Label text="✅ TaskFlow" styleClass="sidebar-logo"/>
                <Label fx:id="welcomeLabel" text="" styleClass="sidebar-user" wrapText="true"/>
                <Label text="Mahasiswa" styleClass="sidebar-role-badge"/>
            </VBox>

            <Separator style="-fx-background-color: #3d5166;"/>

            <Label text="MENU UTAMA" styleClass="sidebar-section-label"/>

            <Button fx:id="btnNavGroup" text="👥  Tugas Kelompok"
                    styleClass="sidebar-btn-active" maxWidth="Infinity"
                    onAction="#showGroupSection"/>
            <Button fx:id="btnNavPersonal" text="📝  Tugas Mandiri"
                    styleClass="sidebar-btn" maxWidth="Infinity"
                    onAction="#showPersonalSection"/>
            <Button text="📊  Statistik" styleClass="sidebar-btn" maxWidth="Infinity"
                    fx:id="btnStatistics" onAction="#handleStatistics"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator style="-fx-background-color: #3d5166;"/>
            <Button text="🚪  Keluar" styleClass="btn-danger-outline sidebar-logout" maxWidth="Infinity"
                    fx:id="btnLogout" onAction="#handleLogout"/>
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="0">

            <!-- Top Bar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="2">
                    <Label text="Dashboard" styleClass="page-title"/>
                    <Label text="Kelola semua tugas kamu di sini" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Clock / Date label can be added here -->
            </HBox>

            <!-- Deadline Reminder Banner -->
            <VBox fx:id="reminderBanner" styleClass="reminder-banner" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🔔 PENGINGAT DEADLINE" styleClass="reminder-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕ Tutup" styleClass="reminder-close" onAction="#dismissReminder"/>
                </HBox>
                <Label fx:id="reminderLabel" styleClass="reminder-text" wrapText="true"/>
            </VBox>

            <!-- GROUP TASKS SECTION -->
            <VBox fx:id="groupSection" VBox.vgrow="ALWAYS" spacing="0">
                <!-- Section header -->
                <HBox styleClass="section-header" alignment="CENTER_LEFT" spacing="8">
                    <Label text="👥 Tugas Kelompok" styleClass="section-title"/>
                    <Label text="Tugas proyek bersama tim" styleClass="section-desc"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusBar" styleClass="status-chip" text=""/>
                </HBox>

                <!-- Filter Bar -->
                <HBox styleClass="filter-bar" alignment="CENTER_LEFT" spacing="10">
                    <TextField fx:id="searchField" promptText="🔍  Cari tugas, proyek..." prefWidth="240" styleClass="search-field"/>
                    <ComboBox fx:id="filterStatus" prefWidth="140"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnAdd" text="➕ Tambah" styleClass="btn-primary" onAction="#handleAdd"/>
                    <Button fx:id="btnEdit" text="✏️ Edit" styleClass="btn-secondary" onAction="#handleEdit"/>
                    <Button fx:id="btnChangeStatus" text="🔄 Status" styleClass="btn-secondary" onAction="#handleChangeStatus"/>
                    <Button fx:id="btnDelete" text="🗑️ Hapus" styleClass="btn-danger" onAction="#handleDelete"/>
                </HBox>

                <!-- Table -->
                <TableView fx:id="taskTable" VBox.vgrow="ALWAYS" styleClass="task-table">
                    <columns>
                        <TableColumn fx:id="colId" text="#" prefWidth="44"/>
                        <TableColumn fx:id="colTitle" text="Judul Tugas" prefWidth="220"/>
                        <TableColumn fx:id="colProject" text="Proyek/Kelompok" prefWidth="150"/>
                        <TableColumn fx:id="colAssigned" text="Ditugaskan Ke" prefWidth="140"/>
                        <TableColumn fx:id="colPriority" text="Prioritas" prefWidth="90"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                        <TableColumn fx:id="colDeadline" text="Deadline" prefWidth="130"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="📋" style="-fx-font-size: 32px;"/>
                            <Label text="Belum ada tugas kelompok" styleClass="table-placeholder-title"/>
                            <Label text="Klik '➕ Tambah' untuk menambahkan tugas baru" styleClass="table-placeholder-sub"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- PERSONAL TASKS SECTION -->
            <VBox fx:id="personalSection" VBox.vgrow="ALWAYS" spacing="0" visible="false" managed="false">
                <!-- Section header -->
                <HBox styleClass="section-header section-header-personal" alignment="CENTER_LEFT" spacing="8">
                    <Label text="📝 Tugas Mandiri" styleClass="section-title"/>
                    <Label text="Tugas pribadi yang kamu kerjakan sendiri" styleClass="section-desc"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="pStatusBar" styleClass="status-chip" text=""/>
                </HBox>

                <!-- Filter Bar -->
                <HBox styleClass="filter-bar" alignment="CENTER_LEFT" spacing="10">
                    <TextField fx:id="pSearchField" promptText="🔍  Cari tugas mandiri..." prefWidth="240" styleClass="search-field"/>
                    <ComboBox fx:id="pFilterStatus" prefWidth="140"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="pBtnAdd" text="➕ Tambah" styleClass="btn-success" onAction="#handlePersonalAdd"/>
                    <Button fx:id="pBtnEdit" text="✏️ Edit" styleClass="btn-secondary" onAction="#handlePersonalEdit"/>
                    <Button fx:id="pBtnChangeStatus" text="🔄 Status" styleClass="btn-secondary" onAction="#handlePersonalChangeStatus"/>
                    <Button fx:id="pBtnDelete" text="🗑️ Hapus" styleClass="btn-danger" onAction="#handlePersonalDelete"/>
                </HBox>

                <!-- Table -->
                <TableView fx:id="personalTable" VBox.vgrow="ALWAYS" styleClass="task-table">
                    <columns>
                        <TableColumn fx:id="pColId" text="#" prefWidth="44"/>
                        <TableColumn fx:id="pColTitle" text="Judul Tugas Mandiri" prefWidth="280"/>
                        <TableColumn fx:id="pColCategory" text="Kategori" prefWidth="140"/>
                        <TableColumn fx:id="pColPriority" text="Prioritas" prefWidth="90"/>
                        <TableColumn fx:id="pColStatus" text="Status" prefWidth="110"/>
                        <TableColumn fx:id="pColDeadline" text="Deadline" prefWidth="130"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="📝" style="-fx-font-size: 32px;"/>
                            <Label text="Belum ada tugas mandiri" styleClass="table-placeholder-title"/>
                            <Label text="Klik '➕ Tambah' untuk menambahkan tugas mandiri kamu" styleClass="table-placeholder-sub"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>
