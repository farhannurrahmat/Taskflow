<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.taskflow.controller.LoginController"
           stylesheets="@../css/style.css"
           styleClass="root-pane login-root">

    <!-- Background decorative shapes -->
    <Pane styleClass="login-bg-deco" mouseTransparent="true"/>

    <VBox styleClass="login-container" maxWidth="460" alignment="CENTER" spacing="0">

        <!-- Logo / Brand -->
        <VBox styleClass="login-brand" alignment="CENTER" spacing="6">
            <Label text="✅" style="-fx-font-size: 44px;"/>
            <Label text="TaskFlow" styleClass="brand-title"/>
            <Label text="Platform Manajemen Tugas Mahasiswa" styleClass="brand-subtitle"/>
        </VBox>

        <!-- Tab buttons -->
        <HBox styleClass="tab-bar" spacing="0">
            <Button fx:id="tabLogin" text="Masuk" styleClass="tab-btn tab-active"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#showLoginPane"/>
            <Button fx:id="tabRegister" text="Daftar Akun" styleClass="tab-btn tab-inactive"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#showRegisterPane"/>
        </HBox>

        <!-- LOGIN PANE -->
        <VBox fx:id="loginPane" styleClass="auth-form" spacing="14">

            <VBox spacing="6">
                <Label text="Username" styleClass="form-label"/>
                <TextField fx:id="usernameField" promptText="Masukkan username" styleClass="form-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" styleClass="form-label"/>
                <PasswordField fx:id="passwordField" promptText="Masukkan password" styleClass="form-input"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label" text="" visible="false" wrapText="true"/>

            <Button fx:id="loginButton" text="Masuk" styleClass="btn-primary btn-full"
                    maxWidth="Infinity" onAction="#handleLogin"/>

        </VBox>

        <!-- REGISTER PANE -->
        <VBox fx:id="registerPane" styleClass="auth-form" spacing="14" visible="false" managed="false">

            <VBox spacing="6">
                <Label text="Nama Lengkap" styleClass="form-label"/>
                <TextField fx:id="regFullNameField" promptText="Masukkan nama lengkap" styleClass="form-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Username" styleClass="form-label"/>
                <TextField fx:id="regUsernameField" promptText="Minimal 4 karakter" styleClass="form-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" styleClass="form-label"/>
                <PasswordField fx:id="regPasswordField" promptText="Minimal 6 karakter" styleClass="form-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Konfirmasi Password" styleClass="form-label"/>
                <PasswordField fx:id="regPasswordConfirmField" promptText="Ulangi password" styleClass="form-input"/>
            </VBox>

            <Label fx:id="regErrorLabel" styleClass="error-label" text="" visible="false" wrapText="true"/>
            <Label fx:id="regSuccessLabel" styleClass="success-label" text="" visible="false" wrapText="true"/>

            <Button fx:id="registerButton" text="Daftar Sekarang" styleClass="btn-success btn-full"
                    maxWidth="Infinity" onAction="#handleRegister"/>
        </VBox>

    </VBox>
</StackPane>
