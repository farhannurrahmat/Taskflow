<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.taskflow.controller.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="0" maxWidth="400" maxHeight="480"
          styleClass="login-card">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8" styleClass="login-header">
            <Label text="✅" styleClass="login-logo"/>
            <Label text="TaskFlow" styleClass="login-title"/>
            <Label text="Manajemen Tugas Mahasiswa" styleClass="login-subtitle"/>
        </VBox>

        <!-- Form -->
        <VBox spacing="16" styleClass="login-form">
            <VBox spacing="6">
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Masukkan username"
                           styleClass="login-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Masukkan password"
                               styleClass="login-field"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <Button fx:id="loginButton" text="Login" onAction="#handleLogin"
                    styleClass="btn-primary" maxWidth="Infinity"/>
        </VBox>

        <!-- Footer hint -->
        <VBox alignment="CENTER" spacing="4" styleClass="login-footer">
            <Label text="Demo: mahasiswa / 1234" styleClass="hint-label"/>
        </VBox>

    </VBox>
</StackPane>
